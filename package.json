{
	"name": "cf-fetch-socks",
	"version": "0.1.2",
	"description": "SOCKS5 proxy fetch for Cloudflare Workers — with TLS, pooling, redirects, and decompression",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "node build.mjs && tsc --emitDeclarationOnly --outDir dist",
		"test": "vitest run",
		"test:unit": "vitest run test/unit/",
		"test:integration": "vitest run test/integration/",
		"test:e2e": "vitest run --config vitest.config.e2e.mts",
		"test:all": "bun test && bun test:e2e",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"prepare": "npm run build",
		"prepublishOnly": "npm run test:unit"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/anomalyco/cf-fetch-socks.git"
	},
	"keywords": [
		"socks5",
		"proxy",
		"cloudflare",
		"workers",
		"fetch",
		"tunnel",
		"tls"
	],
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"@cloudflare/workers-types": "4.20260525.1",
		"@types/node": "^25.9.3",
		"esbuild": "^0.28.1",
		"prettier": "^3.8.4",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.100.0"
	},
	"dependencies": {
		"@reclaimprotocol/tls": "^0.1.3"
	}
}
